<Window x:Class="WebDavSync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WebDavSync"
        Title="WebDavSync"
        Width="500"
        SizeToContent="Height"
        MinWidth="480"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBgBrush}"
        FontFamily="Segoe UI"
        Icon="Assets/app.ico">

    <Window.Resources>
        <!-- Placeholder text style for TextBox -->
        <Style x:Key="PlaceholderTextBox" TargetType="TextBox" BasedOn="{StaticResource InputBox}">
            <Style.Resources>
                <VisualBrush x:Key="PlaceholderBrush" TileMode="None" Stretch="None" AlignmentX="Left" AlignmentY="Center">
                    <VisualBrush.Visual>
                        <TextBlock Foreground="#AAAAAA" FontSize="13" Text="{Binding}" Margin="8,0,0,0"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid Margin="12,10,12,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- LOCAL FOLDER section -->
            <RowDefinition Height="Auto"/>  <!-- SERVER section -->
            <RowDefinition Height="Auto"/>  <!-- OPTIONS section -->
            <RowDefinition Height="Auto"/>  <!-- RECENT ACTIVITY section -->
            <RowDefinition Height="Auto"/>  <!-- Bottom bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- LOCAL FOLDER section                                         -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource SectionCard}">
            <StackPanel>
                <!-- Header row -->
                <Grid Height="38" Margin="14,0,14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="LOCAL FOLDER"
                               Style="{StaticResource SectionHeader}"
                               VerticalAlignment="Center"/>
                    <ToggleButton Grid.Column="1"
                                  x:Name="LocalFolderToggle"
                                  Style="{StaticResource ChevronButton}"
                                  IsChecked="True"
                                  Checked="LocalFolderToggle_Changed"
                                  Unchecked="LocalFolderToggle_Changed"/>
                </Grid>

                <!-- Separator -->
                <Rectangle Height="1" Fill="{StaticResource SectionBorderBrush}" Margin="0,0,0,0"/>

                <!-- Content (collapsible) -->
                <StackPanel x:Name="LocalFolderContent" Margin="14,10,14,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Folder" Style="{StaticResource RowLabel}"/>
                        <TextBox  Grid.Column="1" x:Name="WatchFolderBox" Style="{StaticResource InputBox}"/>
                        <Button   Grid.Column="3" Content="Browse..."
                                  Style="{StaticResource BrowseButton}"
                                  Click="BrowseFolder_Click"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- SERVER section                                               -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{StaticResource SectionCard}">
            <StackPanel>
                <!-- Header row -->
                <Grid Height="38" Margin="14,0,14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="SERVER"
                               Style="{StaticResource SectionHeader}"
                               VerticalAlignment="Center"/>
                    <ToggleButton Grid.Column="1"
                                  x:Name="ServerToggle"
                                  Style="{StaticResource ChevronButton}"
                                  IsChecked="True"
                                  Checked="ServerToggle_Changed"
                                  Unchecked="ServerToggle_Changed"
                                  Margin="2,0,0,0"/>
                    <!-- NOT CONFIGURED warning -->
                    <StackPanel Grid.Column="3"
                                x:Name="NotConfiguredPanel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Path Data="M 7,0 L 14,12 L 0,12 Z"
                              Fill="#E8A020"
                              Width="12" Height="11"
                              Stretch="Fill"
                              Margin="0,0,5,0"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="NOT CONFIGURED"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#888888"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Separator -->
                <Rectangle Height="1" Fill="{StaticResource SectionBorderBrush}"/>

                <!-- Content (collapsible) -->
                <StackPanel x:Name="ServerContent" Margin="14,10,14,14">

                    <!-- URL row -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="URL" Style="{StaticResource RowLabel}"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="UrlBox" Style="{StaticResource InputBox}"/>
                            <TextBlock Text="https://dav.example.com"
                                       Foreground="#AAAAAA"
                                       FontSize="13"
                                       Margin="10,0,0,0"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=UrlBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Grid.Column="3"
                                Style="{StaticResource InfoButton}"
                                Click="OpenUrl_Click"
                                ToolTip="Open URL in browser"/>
                    </Grid>

                    <!-- Username row -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Username" Style="{StaticResource RowLabel}"/>
                        <TextBox   Grid.Column="1" x:Name="UsernameBox" Style="{StaticResource InputBox}"/>
                    </Grid>

                    <!-- Password row -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Password" Style="{StaticResource RowLabel}"/>
                        <PasswordBox x:Name="PasswordBox" Grid.Column="1" Style="{StaticResource InputPasswordBox}"/>
                    </Grid>

                    <!-- Remote folder row -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Remote folder" Style="{StaticResource RowLabel}"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="RemoteFolderBox" Style="{StaticResource InputBox}"/>
                            <TextBlock Text="/"
                                       Foreground="#AAAAAA"
                                       FontSize="13"
                                       Margin="10,0,0,0"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=RemoteFolderBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Grid.Column="3"
                                Content="Browse..."
                                Style="{StaticResource BrowseButton}"
                                Click="BrowseRemote_Click"/>
                    </Grid>

                    <!-- Connect row -->
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ConnectBtn"
                                Style="{StaticResource ConnectButton}"
                                Click="Connect_Click">
                            <StackPanel Orientation="Horizontal">
                                <!-- Chain link icon (Unicode) -->
                                <TextBlock Text="&#x1F517;"
                                           FontSize="13"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Connect"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Connection status dot + text -->
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="14,0,0,0">
                            <Ellipse x:Name="ConnectionDot"
                                     Width="10" Height="10"
                                     Fill="{StaticResource RedDotBrush}"
                                     Margin="0,0,7,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="ConnectionStatusText"
                                       Text="NOT CONNECTED"
                                       FontFamily="Segoe UI"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- OPTIONS section (collapsed by default)                       -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Style="{StaticResource SectionCard}">
            <StackPanel>
                <!-- Header row (clickable to expand) -->
                <Grid Height="38" Margin="14,0,14,0"
                      Cursor="Hand"
                      MouseLeftButtonUp="OptionsHeader_Click">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="OPTIONS"
                               Style="{StaticResource SectionHeader}"
                               VerticalAlignment="Center"/>
                    <ToggleButton Grid.Column="1"
                                  x:Name="OptionsToggle"
                                  Style="{StaticResource ChevronButton}"
                                  IsChecked="False"
                                  Checked="OptionsToggle_Changed"
                                  Unchecked="OptionsToggle_Changed"/>
                </Grid>

                <!-- Content (collapsed by default) -->
                <StackPanel x:Name="OptionsContent"
                            Visibility="Collapsed"
                            Margin="14,4,14,14">
                    <Rectangle Height="1" Fill="{StaticResource SectionBorderBrush}" Margin="0,0,0,10"/>
                    <CheckBox x:Name="StartupCheckBox"
                              Content="Start with Windows"
                              FontFamily="Segoe UI"
                              FontSize="13"
                              Foreground="#333333"
                              Margin="0,0,0,6"/>
                    <CheckBox x:Name="DownloadRemoteCheckBox"
                              Content="Sync remote changes"
                              FontFamily="Segoe UI"
                              FontSize="13"
                              Foreground="#333333"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- RECENT ACTIVITY section (collapsed by default)              -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Style="{StaticResource SectionCard}">
            <StackPanel>
                <!-- Header row -->
                <Grid Height="38" Margin="14,0,14,0"
                      Cursor="Hand"
                      MouseLeftButtonUp="ActivityHeader_Click">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="RECENT ACTIVITY"
                               Style="{StaticResource SectionHeader}"
                               VerticalAlignment="Center"/>
                    <ToggleButton Grid.Column="1"
                                  x:Name="ActivityToggle"
                                  Style="{StaticResource ChevronButton}"
                                  IsChecked="False"
                                  Checked="ActivityToggle_Changed"
                                  Unchecked="ActivityToggle_Changed"/>
                </Grid>

                <!-- Content (collapsed by default) -->
                <StackPanel x:Name="ActivityContent"
                            Visibility="Collapsed"
                            Margin="14,4,14,14">
                    <Rectangle Height="1" Fill="{StaticResource SectionBorderBrush}" Margin="0,0,0,8"/>
                    <ListBox x:Name="ActivityList"
                             Height="140"
                             FontFamily="Consolas"
                             FontSize="11"
                             Foreground="#333333"
                             Background="White"
                             BorderBrush="{StaticResource InputBorderBrush}"
                             BorderThickness="1"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             HorizontalContentAlignment="Stretch"
                             VirtualizingPanel.IsVirtualizing="True"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Bottom bar: version label + Update + Save + Close           -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="4" Margin="4,4,4,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Version label -->
            <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock x:Name="VersionLabel"
                            Text="WEBDAVSYNC V1.0"
                            FontFamily="Segoe UI"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#AAAAAA"/>
                <TextBlock x:Name="UpdateAvailableLabel"
                           Text=""
                           FontFamily="Segoe UI"
                           FontSize="10"
                           Foreground="#2B4FA3"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Update button -->
            <Button Grid.Column="1"
                    x:Name="UpdateBtn"
                    Style="{StaticResource UpdateButton}"
                    Click="Update_Click"
                    IsEnabled="False">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x2B06;" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="UPDATE" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Save button (blue, with save icon) -->
            <Button Grid.Column="3"
                    Style="{StaticResource SaveButton}"
                    Click="Save_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F4BE;" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="SAVE" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Close button -->
            <Button Grid.Column="5"
                    Style="{StaticResource CloseButton}"
                    Click="Close_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x2715;" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="CLOSE" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

    </Grid>
</Window>
