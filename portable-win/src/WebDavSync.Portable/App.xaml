<Application x:Class="WebDavSync.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>

        <!-- ── Colour palette ──────────────────────────────────────────── -->
        <Color x:Key="WindowBg">#F0F0F0</Color>
        <Color x:Key="SectionBg">#F8F8F8</Color>
        <Color x:Key="SectionBorder">#DEDEDE</Color>
        <Color x:Key="LabelGrey">#888888</Color>
        <Color x:Key="InputBorder">#CCCCCC</Color>
        <Color x:Key="InputBg">#FFFFFF</Color>
        <Color x:Key="AccentBlue">#2B4FA3</Color>
        <Color x:Key="AccentBlueHover">#1E3A7A</Color>
        <Color x:Key="RedDot">#E53E3E</Color>
        <Color x:Key="GreenDot">#38A169</Color>

        <SolidColorBrush x:Key="WindowBgBrush"       Color="{StaticResource WindowBg}"/>
        <SolidColorBrush x:Key="SectionBgBrush"      Color="{StaticResource SectionBg}"/>
        <SolidColorBrush x:Key="SectionBorderBrush"  Color="{StaticResource SectionBorder}"/>
        <SolidColorBrush x:Key="LabelGreyBrush"      Color="{StaticResource LabelGrey}"/>
        <SolidColorBrush x:Key="InputBorderBrush"    Color="{StaticResource InputBorder}"/>
        <SolidColorBrush x:Key="InputBgBrush"        Color="{StaticResource InputBg}"/>
        <SolidColorBrush x:Key="AccentBlueBrush"     Color="{StaticResource AccentBlue}"/>
        <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="{StaticResource AccentBlueHover}"/>
        <SolidColorBrush x:Key="RedDotBrush"         Color="{StaticResource RedDot}"/>
        <SolidColorBrush x:Key="GreenDotBrush"       Color="{StaticResource GreenDot}"/>

        <!-- ── Fonts ───────────────────────────────────────────────────── -->
        <FontFamily x:Key="UiFont">Segoe UI</FontFamily>

        <!-- ── TextBox style ──────────────────────────────────────────── -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── PasswordBox style ──────────────────────────────────────── -->
        <Style x:Key="InputPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── Browse / secondary button ─────────────────────────────── -->
        <Style x:Key="BrowseButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="85"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D8D8D8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CACACA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Primary (blue) button ──────────────────────────────────── -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBlueHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#162C5C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Connect button (wide primary) ─────────────────────────── -->
        <Style x:Key="ConnectButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="MinWidth" Value="130"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <!-- ── Info circle button ─────────────────────────────────────── -->
        <Style x:Key="InfoButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                Width="26" Height="26">
                            <TextBlock Text="i"
                                       FontFamily="{StaticResource UiFont}"
                                       FontStyle="Italic"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Section header label ───────────────────────────────────── -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource LabelGreyBrush}"/>
        </Style>

        <!-- ── Row label (Folder, URL, Username…) ─────────────────────── -->
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="110"/>
        </Style>

        <!-- ── Save / Close bottom buttons ───────────────────────────── -->
        <Style x:Key="SaveButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource BrowseButton}">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ── Update button ──────────────────────────────────────────── -->
        <Style x:Key="UpdateButton" TargetType="Button" BasedOn="{StaticResource BrowseButton}">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Expander chevron button ────────────────────────────────── -->
        <Style x:Key="ChevronButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="4">
                            <Path x:Name="Arrow"
                                  Data="M 0,0 L 8,0 L 4,5 Z"
                                  Fill="{StaticResource LabelGreyBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="ArrowRotate" Angle="0"/>
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Section card border ────────────────────────────────────── -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SectionBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SectionBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

    </Application.Resources>
</Application>
